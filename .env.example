# ─── Backend (copy to apps/backend/.env) ────────────────────────────────────
NODE_ENV=development
PORT=3000

# Database — matches docker-compose postgres service (DB is created automatically on first container start)
# Stack uses PostgreSQL + TypeORM only; MongoDB would require a different data layer.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=p2p_ramp
DB_USER=ramp_user
DB_PASSWORD=ramp_pass
DB_SYNC=true
DB_LOGGING=false
DB_RETRY_ATTEMPTS=15
DB_RETRY_DELAY_MS=2000

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_to_a_strong_secret_in_production
JWT_EXPIRES_IN=7d

# Optional (dev): first-boot admin for Admin Panel login — unset in production
SEED_ADMIN_EMAIL=admin@p2pramp.dev
SEED_ADMIN_PASSWORD=ChangeMe123!

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@p2pramp.dev

# Platform wallet (custodial hot wallet — for future blockchain integration)
PLATFORM_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
PLATFORM_WALLET_PRIVATE_KEY=

# Fees
PLATFORM_FEE_PERCENT=0.5

# Frontend URLs (for CORS)
USER_APP_URL=http://localhost:5173
MERCHANT_APP_URL=http://localhost:5174
ADMIN_APP_URL=http://localhost:5175

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VITE_APP_NAME=RampX
